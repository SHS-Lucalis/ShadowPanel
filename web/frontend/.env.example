# API Base URL
# Leave empty to use relative URLs (same domain as frontend)
# Example: VITE_API_BASE_URL=http://localhost:8080
VITE_API_BASE_URL=

# --- Playwright E2E (local runs only; CI sets these as workflow env) ---
# Must match ADMIN_LOGIN / ADMIN_PASSWORD the gameap-api was seeded with.
E2E_ADMIN_USER=admin
E2E_ADMIN_PASSWORD=local-pass
# gameap-api base URL for direct API calls (login, nodes, games).
E2E_API_BASE_URL=http://127.0.0.1:8025
# Docker container running gameap-daemon (heavy project only).
E2E_DAEMON_CONTAINER=gameap-daemon